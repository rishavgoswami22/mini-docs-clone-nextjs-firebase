rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsDoc() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function emailAllowed() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email in resource.data.get('sharedWith', []);
    }

    match /documents/{docId} {
      allow read: if signedIn() && (ownsDoc() || emailAllowed());

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if signedIn()
        && (ownsDoc() || emailAllowed())
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if signedIn() && ownsDoc();
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
